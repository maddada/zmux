{
  "name": "zmux",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "zmux native macOS workarea and sessions UI.",
  "scripts": {
    "start": "native/macos/zmuxHost/run-zmux-host.sh",
    "build": "native/macos/zmuxHost/build-zmux-host.sh",
    "build:sidebar-css": "tailwindcss -i sidebar/styles/shadcn.css -o sidebar/styles/shadcn.generated.css --minify",
    "cli": "node scripts/zmux-cli.mjs",
    "storybook": "bun run build:sidebar-css && storybook dev -p 6006 --no-open",
    "build:storybook": "bun run build:sidebar-css && storybook build",
    "typecheck": "tsc --noEmit --pretty false",
    "test": "vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/abstract": "0.3.2",
    "@dnd-kit/dom": "0.3.2",
    "@dnd-kit/helpers": "0.3.2",
    "@dnd-kit/react": "0.3.2",
    "@fontsource-variable/inter": "^5.2.8",
    "@tabler/icons-react": "^3.40.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.3.0",
    "lucide-react": "^0.561.0",
    "qrcode": "^1.5.4",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-markdown": "^10.1.0",
    "react-syntax-highlighter": "^16.1.0",
    "remark-gfm": "^4.0.1",
    "shadcn": "^4.5.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.4.0",
    "tw-animate-css": "^1.4.0",
    "ws": "^8.20.0",
    "zod": "^4.1.13",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.5",
    "@tailwindcss/cli": "^4.1.17",
    "@types/node": "^25.5.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "storybook": "^10.3.5",
    "typescript": "~5.9.3",
    "vite": "^8.0.10",
    "vitest": "^3.2.4"
  }
}

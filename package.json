{
  "name": "VS-AGENT-MUX",
  "displayName": "VS-AGENT-MUX",
  "version": "0.0.1",
  "private": true,
  "description": "VS-AGENT-MUX - A VS Code extension",
  "categories": [
    "Other"
  ],
  "license": "MIT",
  "author": "maddada",
  "repository": {
    "type": "git",
    "url": "https://github.com/maddada/VS-AGENT-MUX.git"
  },
  "publisher": "maddada",
  "files": [
    "media/**",
    "out/**"
  ],
  "main": "./out/extension/extension.js",
  "scripts": {
    "vscode:prepublish": "vp run sidebar:build && tsc -p ./tsconfig.extension.json && ./scripts/copy-ruspty-native.zsh",
    "sidebar:build": "vp build --config vite.sidebar.config.ts",
    "storybook": "vp exec storybook dev -p 6006 --no-open",
    "storybook:build": "vp exec storybook build",
    "storybook:test": "node ./scripts/storybook-test.mjs",
    "compile": "vp run sidebar:build && tsc -p ./tsconfig.extension.json",
    "watch": "tsc -w -p ./tsconfig.extension.json",
    "lint": "vp lint",
    "fmt": "vp fmt",
    "check": "vp check",
    "prepare": "vp config",
    "vsix:package": "./scripts/vsix.zsh package",
    "vsix:install": "./scripts/vsix.zsh install"
  },
  "dependencies": {
    "@base-ui/react": "^1.3.0",
    "@dnd-kit/react": "^0.3.2",
    "@replit/ruspty": "^3.6.0",
    "@tabler/icons-react": "^3.40.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@storybook/react-vite": "^10.3.0",
    "@storybook/test-runner": "^0.24.3",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/vscode": "^1.110.0",
    "@vitejs/plugin-react": "^6.0.1",
    "@vscode/vsce": "^3.7.1",
    "storybook": "^10.3.0",
    "typescript": "~5.9.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@latest",
    "vite-plus": "latest"
  },
  "contributes": {
    "commands": [
      {
        "command": "VS-AGENT-MUX.openWorkspace",
        "title": "Open Workspace",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.openSettings",
        "title": "Open Settings",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.createSession",
        "title": "New Session",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.revealSession",
        "title": "Reveal Session",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.restartSession",
        "title": "Restart Session",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.renameActiveSession",
        "title": "Rename Active Session",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup1",
        "title": "Focus Group 1",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup2",
        "title": "Focus Group 2",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup3",
        "title": "Focus Group 3",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup4",
        "title": "Focus Group 4",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusUp",
        "title": "Focus Up",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusRight",
        "title": "Focus Right",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusDown",
        "title": "Focus Down",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusLeft",
        "title": "Focus Left",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "title": "Focus Session Slot",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showOne",
        "title": "Show 1 Terminal",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showTwo",
        "title": "Show 2 Terminals",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showThree",
        "title": "Show 3 Terminals",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showFour",
        "title": "Show 4 Terminals",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showSix",
        "title": "Show 6 Terminals",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.showNine",
        "title": "Show 9 Terminals",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.toggleFullscreenSession",
        "title": "Toggle Fullscreen Session",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.setHorizontalView",
        "title": "Set Horizontal View",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.setVerticalView",
        "title": "Set Vertical View",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.setGridView",
        "title": "Set Grid View",
        "category": "VS-AGENT-MUX"
      },
      {
        "command": "VS-AGENT-MUX.resetWorkspace",
        "title": "Reset Workspace",
        "category": "VS-AGENT-MUX"
      }
    ],
    "viewsContainers": {
      "secondarySidebar": [
        {
          "id": "VS-AGENT-MUXSessions",
          "title": "VS-AGENT-MUX",
          "icon": "media/VS-AGENT-MUX.svg"
        }
      ]
    },
    "views": {
      "VS-AGENT-MUXSessions": [
        {
          "type": "webview",
          "id": "VS-AGENT-MUX.sessions",
          "name": "Sessions"
        }
      ]
    },
    "configuration": {
      "title": "VS-AGENT-MUX",
      "properties": {
        "VS-AGENT-MUX.backgroundSessionTimeoutMinutes": {
          "type": "number",
          "minimum": 0,
          "default": 5,
          "description": "How long detached background sessions stay alive after the last VS-AGENT-MUX window disconnects. Set to 0 to keep sessions alive until they exit or are explicitly closed."
        },
        "VS-AGENT-MUX.sidebarTheme": {
          "type": "string",
          "default": "auto",
          "enum": [
            "auto",
            "plain",
            "dark-green",
            "dark-blue",
            "dark-red",
            "dark-pink",
            "dark-orange",
            "light-blue",
            "light-green",
            "light-pink",
            "light-orange"
          ],
          "enumItemLabels": [
            "Auto",
            "Plain",
            "Dark Green",
            "Dark Blue",
            "Dark Red",
            "Dark Pink",
            "Dark Orange",
            "Light Blue",
            "Light Green",
            "Light Pink",
            "Light Orange"
          ],
          "enumDescriptions": [
            "Follows the active VS Code theme: Dark Blue in dark themes and Light Blue in light themes.",
            "A neutral grayscale theme that follows the active VS Code light or dark mode.",
            "A very dark green-tinted palette with a muted emerald accent.",
            "A very dark blue-tinted palette with a muted cobalt accent.",
            "A very dark red-tinted palette with a muted crimson accent.",
            "A very dark pink-tinted palette with a muted rose accent.",
            "A very dark orange-tinted palette with a muted amber accent.",
            "A light blue-tinted palette with a crisp cobalt accent.",
            "A light green-tinted palette with a soft emerald accent.",
            "A light pink-tinted palette with a rose accent.",
            "A light orange-tinted palette with an amber accent."
          ],
          "description": "Theme preset used by the VS-AGENT-MUX sidebar app. Auto follows the active VS Code light or dark theme."
        },
        "VS-AGENT-MUX.debuggingMode": {
          "type": "boolean",
          "default": false,
          "description": "Show debugging UI such as the active terminal backend indicator in the status bar."
        },
        "VS-AGENT-MUX.zmxBinaryPathOverride": {
          "type": "string",
          "default": "",
          "description": "Absolute path to a custom zmx binary. When set, VS-AGENT-MUX uses this binary instead of downloading the pinned upstream zmx release."
        },
        "VS-AGENT-MUX.showCloseButtonOnSessionCards": {
          "type": "boolean",
          "default": false,
          "description": "Show close button on session cards. You can always cmd + click or middle click on a card to close it."
        },
        "VS-AGENT-MUX.showHotkeysOnSessionCards": {
          "type": "boolean",
          "default": false,
          "description": "Show hotkey labels on session cards all the time instead of only revealing them when you hover a card."
        },
        "VS-AGENT-MUX.completionSound": {
          "type": "string",
          "default": "ping",
          "enum": [
            "arcade",
            "codecompleteafrican",
            "codecompleteafrobeat",
            "codecompleteedm",
            "comebacktothecode",
            "glass",
            "ping",
            "shamisen",
            "supersetdoowap",
            "supersetquick"
          ],
          "enumItemLabels": [
            "Arcade",
            "African Code Complete",
            "Afrobeat Code Complete",
            "EDM Code Complete",
            "Come Back To The Code",
            "Glass",
            "Ping",
            "Shamisen",
            "Superset Doo-Wap",
            "Superset Quick"
          ],
          "description": "Sound played when an agent finishes and the per-project bell is enabled in the VS-AGENT-MUX sidebar."
        },
        "VS-AGENT-MUX.sendRenameCommandOnSidebarRename": {
          "type": "boolean",
          "default": true,
          "description": "When renaming a session from the sidebar, also stage `/rename <new name>` in that terminal and focus it without pressing Enter."
        }
      }
    },
    "keybindings": [
      {
        "command": "VS-AGENT-MUX.focusGroup1",
        "key": "ctrl+alt+shift+1",
        "mac": "ctrl+alt+shift+1",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup2",
        "key": "ctrl+alt+shift+2",
        "mac": "ctrl+alt+shift+2",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup3",
        "key": "ctrl+alt+shift+3",
        "mac": "ctrl+alt+shift+3",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.focusGroup4",
        "key": "ctrl+alt+shift+4",
        "mac": "ctrl+alt+shift+4",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.showSix",
        "key": "ctrl+alt+shift+6",
        "mac": "cmd+alt+shift+6",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.showNine",
        "key": "ctrl+alt+shift+9",
        "mac": "cmd+alt+shift+9",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 1,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+1",
        "mac": "cmd+alt+1",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 2,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+2",
        "mac": "cmd+alt+2",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 3,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+3",
        "mac": "cmd+alt+3",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 4,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+4",
        "mac": "cmd+alt+4",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 5,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+5",
        "mac": "cmd+alt+5",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 6,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+6",
        "mac": "cmd+alt+6",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 7,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+7",
        "mac": "cmd+alt+7",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 8,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+8",
        "mac": "cmd+alt+8",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "args": 9,
        "command": "VS-AGENT-MUX.focusSessionSlot",
        "key": "ctrl+alt+9",
        "mac": "cmd+alt+9",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.setHorizontalView",
        "key": "ctrl+alt+h",
        "mac": "cmd+alt+h",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.setVerticalView",
        "key": "ctrl+alt+v",
        "mac": "cmd+alt+v",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.setGridView",
        "key": "ctrl+alt+g",
        "mac": "cmd+alt+g",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.renameActiveSession",
        "key": "ctrl+alt+r",
        "mac": "cmd+alt+r",
        "when": "!inputFocus || terminalFocus"
      },
      {
        "command": "VS-AGENT-MUX.toggleFullscreenSession",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "terminalFocus"
      },
      {
        "command": "workbench.action.toggleMaximizedPanel",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "panelFocus && !terminalFocus"
      },
      {
        "command": "workbench.action.toggleMaximizeEditorGroup",
        "key": "ctrl+alt+f",
        "mac": "cmd+alt+f",
        "when": "!panelFocus && !terminalFocus"
      }
    ]
  },
  "activationEvents": [
    "onStartupFinished",
    "onView:VS-AGENT-MUX.sessions"
  ],
  "engines": {
    "vscode": "^1.110.0"
  },
  "packageManager": "pnpm@10.14.0",
  "pnpm": {
    "overrides": {
      "vite": "npm:@voidzero-dev/vite-plus-core@latest",
      "vitest": "npm:@voidzero-dev/vite-plus-test@latest"
    }
  }
}
